{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Reader",
  "version": "0.3.0",
  "identifier": "com.senguoyun.md-reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MD Reader",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "signingIdentity": null,
      "minimumSystemVersion": "10.13"
    },
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "mimeType": "text/markdown",
        "role": "Editor",
        "description": "Markdown Document"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/shehuiyao/mdreader/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDA0N0VGQ0VFRDgzRkUyNzgKUldSNDRqL1k3dngrQkZhQ29tS2ZtM254ZHlGVUpTcllscnBjbWE5aVdyTExHY2p2MHYxUW44OHEK"
    }
  }
}
