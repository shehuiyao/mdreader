{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "store:default",
    "fs:default",
    "updater:default",
    "process:default",
    {
      "identifier": "fs:allow-watch",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-unwatch"
    }
  ]
}
